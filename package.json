{
  "name": "guardrails",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:web & pnpm run dev:api & wait",
    "dev:web": "portless guardrails pnpm --filter @guardrails/web dev:app",
    "dev:api": "portless api.guardrails pnpm --filter @guardrails/api dev:app",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @guardrails/web test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @guardrails/db db:migrate",
    "db:studio": "pnpm --filter @guardrails/db db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "portless": "^0.4.0",
    "vitest": "^3.0.5",
    "typescript": "^5.7.3"
  }
}
