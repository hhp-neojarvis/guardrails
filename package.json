{
  "name": "guardrails",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:web & pnpm run dev:api & pnpm run dev:tunnel & wait",
    "dev:tunnel": "ngrok http 3001 --domain unhealthy-marcos-focal.ngrok-free.dev",
    "dev:web": "pnpm --filter @guardrails/web dev:app",
    "dev:api": "pnpm --filter @guardrails/api dev:app",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @guardrails/web test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @guardrails/db db:migrate",
    "db:seed": "pnpm --filter @guardrails/db db:seed",
    "db:studio": "pnpm --filter @guardrails/db db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "vitest": "^3.0.5",
    "typescript": "^5.7.3"
  }
}
